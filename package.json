{
  "private": true,
  "sideEffects": false,
  "scripts": {
    "prebuild": "prismic-ts-codegen",
    "build": "run-s \"build:*\"",
    "build:css": "tailwindcss -i ./styles/tailwind.css -o ./app/styles/tailwind.css --minify",
    "build:remix": "remix build",
    "predev": "prismic-ts-codegen",
    "dev": "run-p \"dev:*\"",
    "dev:css": "tailwindcss -i ./styles/tailwind.css -o ./app/styles/tailwind.css --watch",
    "dev:remix": "remix dev",
    "start": "remix-serve build",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@prismicio/client": "^6.7.3",
    "@remix-run/node": "^1.9.0",
    "@remix-run/react": "^1.9.0",
    "@remix-run/vercel": "^1.9.0",
    "@vercel/node": "^2.6.2",
    "dayjs": "^1.11.7",
    "flowbite": "^1.6.0",
    "flowbite-react": "^0.3.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.7.1"
  },
  "devDependencies": {
    "@prismicio/types": "^0.2.7",
    "@remix-run/dev": "^1.9.0",
    "@remix-run/eslint-config": "^1.9.0",
    "@remix-run/serve": "^1.9.0",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.8",
    "dotenv": "^16.0.3",
    "eslint": "^8.27.0",
    "eslint-config-codely": "^2.1.3",
    "npm-run-all": "^4.1.5",
    "prismic-ts-codegen": "^0.1.5",
    "tailwindcss": "^3.2.4",
    "typescript": "^4.8.4"
  },
  "engines": {
    "node": ">=14"
  }
}
