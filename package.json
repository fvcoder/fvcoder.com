{
  "name": "remix-template-vercel",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "cross-env NODE_ENV=production run-s build-remix build-css",
    "build-remix": "remix build",
    "build-css": "postcss ./style/index.css -o ./app/style/main.css",
    "predev": "npm run build-css",
    "dev": "cross-env NODE_ENV=development run-p dev-*",
    "dev-remix": "remix dev",
    "dev-css": "postcss ./style/index.css -o ./app/style/main.css -w"
  },
  "dependencies": {
    "@remix-run/node": "^1.5.1",
    "@remix-run/react": "^1.5.1",
    "@remix-run/vercel": "^1.5.1",
    "@vercel/node": "^1.15.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.5.1",
    "@remix-run/eslint-config": "^1.5.1",
    "@remix-run/serve": "^1.5.1",
    "@types/react": "^17.0.45",
    "@types/react-dom": "^17.0.17",
    "autoprefixer": "^10.4.7",
    "cross-env": "^7.0.3",
    "cssnano": "^5.1.9",
    "eslint": "^8.15.0",
    "flowbite": "^1.4.7",
    "flowbite-react": "^0.0.25",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.14",
    "postcss-cli": "^9.1.0",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.6.4"
  },
  "engines": {
    "node": ">=14"
  }
}
