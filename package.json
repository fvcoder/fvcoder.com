  "scripts": {
    "build": "run-s build:css pwa build:remix",
    "build:remix": "remix build",
    "build:css": "tailwindcss -m -i ./styles/app.css -o app/styles/app.css",
    "dev": "run-p dev-*",
    "dev-remix": "node -r dotenv/config ./node_modules/@remix-run/dev/cli.js",
    "dev-css": "tailwindcss -w -i ./styles/app.css -o app/styles/app.css",
    "postinstall": "remix setup node",
    "pwa": "run-s pwa:*",
    "pwa:esbuild": "esbuild --outfile=pwa/sw.js --bundle pwa/index.ts",
    "pwa:manifest": "workbox injectManifest workbox-config.js"
  },
