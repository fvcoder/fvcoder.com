{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "com-fvcoder",
  "compatibility_date": "2026-04-15",
  "pages_build_output_dir": "./dist",
  "routes": [
    {
        "custom_domain": true,
        "pattern": "fvcoder.com"
    },
    {
        "custom_domain": true,
        "pattern": "www.fvcoder.com"
    }
  ]
}