---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { HeaderNavbar } from "../../components/react/headerNavbar";
import Navbar from "../../components/Navbar.astro";

const posts = (await getCollection("blog")).sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={`Blog de ${SITE_TITLE}`}
      description={"Fernando Ticona: Tu aliado en el desarrollo frontend. Convierte tus ideas en realidad digital. Experto en HTML, CSS, JavaScript, React y Vue.js. Diseño web moderno, rápido y responsivo. ¡Llevemos tu proyecto al siguiente nivel!"}
    />
  </head>
  <body class="bg-background text-foreground">
    <Navbar />
    <main class="mx-auto max-w-5xl px-4 py-4 md:px-6">
      <section class="rounded-[2rem] bg-white p-6 md:p-8">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.35em] text-neutral-500">Blog</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight text-neutral-900 md:text-4xl">Ideas, aprendizajes y criterio técnico</h1>
          </div>
          <p class="max-w-xl text-sm leading-7 text-neutral-600">Lecturas sin imágenes para que el contenido tenga más peso y más aire.</p>
        </div>

        <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {
            posts.map((post: any) => (
              <li>
                <a href={`/blog/${post.id}/`} class="group flex h-full flex-col rounded-[1.75rem] border border-neutral-200 bg-neutral-50 p-6 transition hover:-translate-y-1 hover:bg-white hover:shadow-[0_20px_50px_rgba(0,0,0,0.08)]">
                  <div class="flex items-center justify-between gap-4">
                    <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">Artículo</span>
                    <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">Leer</span>
                  </div>
                  <h2 class="mt-4 text-2xl font-semibold tracking-tight text-neutral-900 group-hover:text-neutral-700">{post.data.title}</h2>
                  <p class="mt-3 line-clamp-4 text-sm leading-7 text-neutral-600">{post.data.description}</p>
                  <div class="mt-6 border-t border-neutral-200 pt-4 text-sm text-neutral-500">
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
