---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { getCollection } from "astro:content";
import Navbar from "../../components/Navbar.astro";
import ContentCard from "../../components/ContentCard.astro";

const posts = (await getCollection("blog")).sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={`Blog de ${SITE_TITLE}`}
      description={"Artículos sobre desarrollo frontend, automatización y criterio técnico para construir software útil y bien resuelto."}
    />
  </head>
  <body class="bg-background text-foreground">
    <Navbar />
    <main class="mx-auto max-w-5xl px-4 py-4 md:px-6">
      <section class="rounded-[2rem] bg-white p-6 md:p-8">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.35em] text-neutral-500">Blog</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight text-neutral-900 md:text-4xl">Ideas, aprendizajes y criterio técnico</h1>
          </div>
          <p class="max-w-xl text-sm leading-7 text-neutral-600">Lecturas sin imágenes para que el contenido tenga más peso y más aire.</p>
        </div>

        <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {
            posts.map((post: any) => (
              <li>
                <ContentCard
                  href={`/blog/${post.id}/`}
                  label="Artículo"
                  topRightLabel="Leer"
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.pubDate}
                />
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
