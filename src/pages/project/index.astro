---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import Navbar from "../../components/Navbar.astro";

const posts = (await getCollection("project")).sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={`Proyectos realizados por ${SITE_TITLE}`}
      description={"Soy Fernando Ticona, desarrollador frontend especializado en crear sitios web rápidos, modernos y responsivos. Mi objetivo es transformar tus ideas en experiencias digitales únicas, utilizando tecnologías como HTML, CSS, JavaScript y frameworks como React y Vue.js. Si buscas llevar tu proyecto web al siguiente nivel, aquí encontrarás una selección de mis proyectos, que muestran mi enfoque en diseño, usabilidad y optimización de rendimiento. Explora mi trabajo y descubre cómo puedo ayudarte a crear una solución web a medida que cumpla con tus expectativas."}
    />
  </head>
  <body class="bg-background text-foreground">
    <Navbar client:visible />
    <main class="mx-auto max-w-5xl px-4 py-4 md:px-6">
      <section class="rounded-[2rem] bg-white p-6 md:p-8">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.35em] text-neutral-500">Proyectos</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight text-neutral-900 md:text-4xl">Casos recientes, sin distracciones visuales</h1>
          </div>
          <p class="max-w-xl text-sm leading-7 text-neutral-600">El foco queda en el problema, la solución y el resultado.</p>
        </div>

        <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {
            posts.map((post: any) => (
              <li>
                <a href={`/project/${post.id}/`} class="group flex h-full flex-col rounded-[1.75rem] border border-neutral-200 bg-neutral-50 p-6 transition hover:-translate-y-1 hover:bg-white hover:shadow-[0_20px_50px_rgba(0,0,0,0.08)]">
                  <div class="flex items-center justify-between gap-4">
                    <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">Proyecto</span>
                    <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">Ver</span>
                  </div>
                  <h2 class="mt-4 text-2xl font-semibold tracking-tight text-neutral-900 group-hover:text-neutral-700">{post.data.title}</h2>
                  <p class="mt-3 line-clamp-4 text-sm leading-7 text-neutral-600">{post.data.role}</p>
                  <div class="mt-6 border-t border-neutral-200 pt-4 text-sm text-neutral-500">
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
