---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { HeaderNavbar } from "../components/react/headerNavbar";
import { ContributionGraph } from "../components/react/contributionGraph";
import { getCollection } from "astro:content";
import { Button } from "@heroui/react";
import MainLayout from "../layouts/Main.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { Chip } from "@heroui/react";

const socialData = [
  {
    icon: "icon-[devicon--github]",
    label: "GitHub",
    href: "https://github.com/fvcoder",
  },
  {
    icon: "icon-[devicon--linkedin]",
    label: "Linkedin",
    href: "https://linkedin.com/in/fvcoder",
  },
  {
    icon: "icon-[devicon--figma]",
    label: "Figma",
    href: "https://figma.com/@fvcoder",
  },
  {
    icon: "icon-[simple-icons--tiktok]",
    label: "Tiktok",
    href: "https://gitlab.com/fvcoder",
  },
];

const project = (await getCollection("project")).sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
}).slice(0, 2);


const blog = (await getCollection("blog")).sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
}).slice(0, 4);
---
<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="max-w-5xl px-4 py-10 mx-auto grid grid-cols-2 gap-4">
    <div>
      <div>
        <Chip variant="soft" color="accent">
          <span class="icon-[fluent--search-sparkle-16-filled] mr-1"></span>
          Buscando nuevos retos
        </Chip>
        <div class="my-4">
          <p class="text-5xl font-semibold leading-[1.15]">Creo soluciones que ahorran tiempo y dinero</p>
        </div>
        <div class="text-muted">
          Tengo 2 años de experiencia creando en soluciones útiles y realistas, automatizando procedimientos, ahorrando tiempo, aumentando la eficiencia.
        </div>
        <div class="mt-4">
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSdy0BHpgKt0iBZq6a9dsHXJ0Suy-4p1HDFm2gEUOsaEnfpqFw/viewform?usp=publish-editor" class="button button--primary">Contactar ahora</a>
        </div>
      </div>
    </div>

    <div class="grid gap-2 grid-cols-4">
      <div class="col-span-2 animate-fade-in-up animate-delay-100">
        <div class="rounded-2xl aspect-square">
          <img src="/2.png" class=" rounded-2xl" />
        </div>
      </div>
      <div class="col-span-2 animate-fade-in-up animate-delay-200">
        <div class="aspect-square">
          <img src="https://github.com/fvcoder.png" class="size-full object-cover rounded-2xl" />
        </div>
      </div>
      <div class="animate-fade-in-up animate-delay-300 bg-linear-to-r from-blue-500 via-60% via-sky-500 to-emerald-500 rounded-2xl col-span-3 h-full p-2 text-white">
        <p class="text-sm text-pretty hidden">Las empresas recientes con las que he trabajado</p>
      </div>
      <div class="animate-fade-in-up animate-delay-400 rounded-2xl col-span-1 h-full aspect-square grid grid-cols-2 gap-4  place-items-center">
        {socialData.slice(0, 4).map((x) => (
          <a class="button button--tertiary aspect-square size-12 bg-white p-2" href={x.href} title={x.label}>
            <i class={`${x.icon} text-2xl`}></i>
          </a>
        ))}
      </div>
    </div>
  </div>

  <section class="max-w-5xl p-4 mx-auto">sad</section>

    <section class="max-w-5xl mx-auto px-6">
      <div class="mb-8">
        <h2 class="font-incognito text-3xl font-semibold tracking-tight">
          Gráfico de Contribuciones de código
        </h2>
      </div>
      <div>
        <ContributionGraph client:visible />
      </div>
    </section>
    <section class="max-w-5xl mx-auto px-6 mt-20">
      <div class="mb-8">
        <h2 class="font-incognito text-3xl font-semibold tracking-tight">
          Proyectos
        </h2>
        <p class="font-incognito text-base mt-2 tracking-tight text-default-800">
          Los últimos proyectos en los cuales participe
        </p>
      </div>
      <main class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          project.map((x) => (
            <article>
              <a href={`/project/${x.id}`} class="block">
                <img
                  src={x.data.heroImage}
                  alt=""
                  class="w-full h-auto aspect-video object-cover rounded-xl"
                />
              </a>
              <div class="flex justify-between items-start mt-4">
                <div>
                  <a href={`/project/${x.id}`} class="block">
                    <h3 class="text-xl font-semibold">{x.data.title}</h3>
                  </a>
                  <p class="text-neutral-500">{x.data.role}</p>
                </div>
                <div>
                  <Button
                    as="a"
                    href={`/project/${x.id}`}
                    size="sm"
                    variant="ghost"
                    client:visible
                  >
                    Ver caso de estudio
                  </Button>
                </div>
              </div>
            </article>
          ))
        }
      </main>
    </section>
    <section class="max-w-5xl mx-auto px-6 mt-20">
      <div class="mb-8">
        <h2 class="font-incognito text-3xl font-semibold tracking-tight">
          Blog
        </h2>
        <p class="font-incognito text-base mt-2 tracking-tight text-default-800">
          Aquí demuestro mi crecimiento diario...
        </p>
      </div>
      <main class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          blog.map((post) => (
            <article>
              <a href={`/blog/${post.id}/`} class="block">
                  <img
                    src={post.data.heroImage}
                    alt={`${post.data.title} portada`}
                    class="object-cover w-full h-auto rounded-xl"
                  />
                  <h4 class="mt-2 text-2xl font-semibold">{post.data.title}</h4>
                  <p class="text-neutral-500">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </a>
            </article>
          ))
        }
      </main>
    </section>
</MainLayout>
