---
import FormattedDate from "./FormattedDate.astro";

interface Props {
  href: string;
  label: string;
  title: string;
  description: string;
  date: Date;
  topRightLabel: string;
}

const { href, label, title, description, date, topRightLabel } = Astro.props;
---

<a href={href} class="group flex h-full flex-col rounded-[1.75rem] border border-neutral-200 bg-neutral-50 p-6 transition hover:-translate-y-1 hover:bg-white hover:shadow-[0_20px_50px_rgba(0,0,0,0.08)]">
  <div class="flex items-center justify-between gap-4">
    <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">{label}</span>
    <span class="text-xs uppercase tracking-[0.3em] text-neutral-400">{topRightLabel}</span>
  </div>
  <h2 class="mt-4 text-2xl font-semibold tracking-tight text-neutral-900 group-hover:text-neutral-700">{title}</h2>
  <p class="mt-3 line-clamp-4 text-sm leading-7 text-neutral-600">{description}</p>
  <div class="mt-6 border-t border-neutral-200 pt-4 text-sm text-neutral-500">
    <FormattedDate date={date} />
  </div>
</a>