---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: string
}

const canonicalURL = new URL(Astro.url.pathname, "https://fvcoder.com");
const siteURL = "https://fvcoder.com";

const { description, image } = Astro.props;
const type = Astro.props.type ?? "website"
const title = type === "article" ? `${Astro.props.title} | Fernando Ticona` : Astro.props.title
const socialImage = image ? new URL(image, Astro.url).toString() : `${siteURL}/brand/bn/fvcoder-2025.webp`;
const robots = "index, follow, max-snippet:160, max-image-preview:large, max-video-preview:-1";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content={robots} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="theme-color" content="#3a261c" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />
<meta property="og:site_name" content="Fernando Ticona" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImage} />

<script type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Fernando Ticona",
	"url": siteURL,
	"jobTitle": "Desarrollador frontend",
	"sameAs": [
		"https://github.com/fvcoder",
		"https://linkedin.com/in/fvcoder",
		"https://figma.com/@fvcoder"
	]
})} />

<!-- Favicon -->
<link rel="icon" type="image/png" href="https://cdn.fvcoder.com/icon/2024-12/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="https://cdn.fvcoder.com/icon/2024-12/favicon.svg" />
<link rel="shortcut icon" href="https://cdn.fvcoder.com/icon/2024-12/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="https://cdn.fvcoder.com/icon/2024-12/apple-touch-icon.png" />

<script defer src="https://cloud.umami.is/script.js" data-website-id="4c1454a5-165c-4ff8-b182-c7c0b6d58f80"></script>